{
    "name": "worker",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "GOOS=js GOARCH=wasm go build -trimpath -ldflags='-s -w -buildid=' -o app.wasm main.go && cp $(go env GOROOT)/lib/wasm/wasm_exec.js wasm_exec.js",
        "deploy": "wrangler deploy",
        "dev": "wrangler dev",
        "start": "wrangler dev",
        "test": "vitest",
        "cf-typegen": "wrangler types"
    },
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.12.4",
        "@types/node": "^25.9.2",
        "typescript": "^5.5.2",
        "vitest": "~3.2.0",
        "wrangler": "^4.98.0"
    }
}
